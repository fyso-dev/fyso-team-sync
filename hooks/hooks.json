{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/tracking.sh agent_dispatch",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/tracking.sh session_start",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "nohup ${CLAUDE_PLUGIN_ROOT}/hooks/heartbeat.sh </dev/stdin >/dev/null 2>&1 &",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/tracking.sh subagent_start",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/tracking.sh subagent_stop",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "kill $(cat ~/.fyso/heartbeat.pid 2>/dev/null) 2>/dev/null; ${CLAUDE_PLUGIN_ROOT}/hooks/tracking.sh session_end",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
